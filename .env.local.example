# =========================================================================
# KORYOGRAPH SUITE — Local Environment Variables
# Copy this file to '.env.local' and fill in your Supabase credentials.
# =========================================================================

# 1. Supabase Settings (Get these from your Supabase Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_ROLE_KEY=your-secure-service-role-key-here

# 2. Local/Production Domain Configurations
# For local dev, use localhost. For production, use koryograph.ai
NEXT_PUBLIC_ROOT_DOMAIN=localhost
NEXT_PUBLIC_COOKIE_DOMAIN=localhost
NODE_ENV=development
